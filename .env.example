# Database
# For local dev (Docker): postgresql://finlife_app:Password%21%40%23%24@localhost:5432/finlife_dev
# For Neon: postgresql://[role]:[password]@[endpoint]-pooler.[region].aws.neon.tech/[dbname]?sslmode=require&channel_binding=require
DATABASE_URL="postgresql://neondb_owner:[YOUR-PASSWORD]@[YOUR-ENDPOINT]-pooler.[REGION].aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Clerk
CLERK_SECRET_KEY="sk_test_your_secret_key"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_publishable_key"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/overview"
