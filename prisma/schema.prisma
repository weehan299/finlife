generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ─────────────────────────────────────────────

enum InputMode {
  QUICK
  DETAILED
}

enum InputProvenance {
  USER_ENTERED
  USER_ESTIMATED
  SYSTEM_DEFAULT
}

enum AssetCategory {
  CASH_CHECKING
  SAVINGS
  INVESTMENTS
  RETIREMENT
  PROPERTY
  OTHER
}

enum LiabilityCategory {
  CREDIT_CARD
  STUDENT_LOAN
  PERSONAL_LOAN
  MORTGAGE
  OTHER
}

enum IncomeCategory {
  TAKE_HOME
  GROSS
  OTHER_RECURRING
  VARIABLE
  FALLBACK
}

enum ExpenseCategory {
  ESSENTIAL_FIXED
  ESSENTIAL_VARIABLE
  DISCRETIONARY
}

enum GoalType {
  SAVINGS
  RETIREMENT
  FINANCIAL_INDEPENDENCE
  CUSTOM
}

enum GoalAssetAllocationMode {
  FULL_VALUE
  FIXED_AMOUNT
  PERCENT_OF_VALUE
}

enum DecisionTemplate {
  HOME_PURCHASE
  NEW_LOAN
  LARGE_PURCHASE
  INCOME_LOSS
  RECURRING_EXPENSE
  ONE_TIME_EXPENSE
}

enum DecisionStatus {
  DRAFT
  EVALUATED
  ARCHIVED
}

enum DecisionVerdict {
  PASS
  CAUTION
  FAIL
}

enum OutputConfidence {
  HIGH
  MEDIUM
  LOW
}

// ─── MODELS ────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  clerkUserId        String    @unique
  email              String?
  displayName        String?
  dateOfBirth        DateTime?
  onboardingComplete Boolean   @default(false)
  mode               InputMode @default(QUICK)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  settings    UserSettings?
  assets      Asset[]
  liabilities Liability[]
  incomes     Income[]
  expenses    Expense[]
  goals       Goal[]
  decisions   Decision[]

  @@index([createdAt])
}

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique

  // Percent fields stored as decimal fractions: 3% => 0.03, 36% => 0.36
  inflationRate        Decimal @default(0.03)  @db.Decimal(5, 4)
  investmentGrowthRate Decimal @default(0.05)  @db.Decimal(5, 4)
  savingsInterestRate  Decimal @default(0.015) @db.Decimal(5, 4)
  debtInterestFallback Decimal @default(0.08)  @db.Decimal(5, 4)
  safeWithdrawalRate   Decimal @default(0.04)  @db.Decimal(5, 4)

  minEmergencyMonths  Int     @default(6)
  minPostDecisionCash Decimal @default(0)    @db.Decimal(14, 2)
  minMonthlySurplus   Decimal @default(0)    @db.Decimal(14, 2)
  maxDebtToIncome     Decimal @default(0.36) @db.Decimal(5, 4)
  maxHousingRatio     Decimal @default(0.28) @db.Decimal(5, 4)

  // Editable defaults for housing + stress mode
  housingTaxRateDefault          Decimal? @db.Decimal(7, 4)
  housingInsuranceMonthlyDefault Decimal? @db.Decimal(14, 2)
  housingMaintenanceRateDefault  Decimal? @db.Decimal(7, 4)
  stressExpenseReductionDefault  Decimal? @db.Decimal(5, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Asset {
  id                       String          @id @default(cuid())
  userId                   String
  category                 AssetCategory
  label                    String
  value                    Decimal         @db.Decimal(14, 2)
  isLiquid                 Boolean         @default(false)
  monthlyContribution      Decimal?        @db.Decimal(14, 2)
  annualGrowthRateOverride Decimal?        @db.Decimal(5, 4)
  provenance               InputProvenance @default(USER_ENTERED)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalAllocations GoalAssetAllocation[]

  @@index([userId, category])
  @@index([userId, isLiquid])
}

model Liability {
  id                  String            @id @default(cuid())
  userId              String
  category            LiabilityCategory
  label               String
  balance             Decimal           @db.Decimal(14, 2)
  annualInterestRate  Decimal?          @db.Decimal(5, 4)
  minimumPayment      Decimal?          @db.Decimal(14, 2)
  remainingTermMonths Int?
  provenance          InputProvenance   @default(USER_ENTERED)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
}

model Income {
  id            String          @id @default(cuid())
  userId        String
  category      IncomeCategory
  label         String
  monthlyAmount Decimal         @db.Decimal(14, 2)
  isGuaranteed  Boolean         @default(true)
  provenance    InputProvenance @default(USER_ENTERED)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([userId, isGuaranteed])
}

model Expense {
  // expense refers to both fixed and variable expenses, aim to track things like daily expenses or one time expense
  id                  String          @id @default(cuid())
  userId              String
  category            ExpenseCategory
  label               String
  monthlyAmount       Decimal         @db.Decimal(14, 2)
  stressMonthlyAmount Decimal?        @db.Decimal(14, 2)
  isEssential         Boolean         @default(true)
  provenance          InputProvenance @default(USER_ENTERED)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([userId, isEssential])
}

model Goal {
  id                  String          @id @default(cuid())
  userId              String
  type                GoalType
  name                String
  targetAmount        Decimal         @db.Decimal(14, 2)
  targetDate          DateTime?
  startingAmount      Decimal         @default(0) @db.Decimal(14, 2)
  monthlyContribution Decimal         @default(0) @db.Decimal(14, 2)
  provenance          InputProvenance @default(USER_ENTERED)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetAllocations GoalAssetAllocation[]
  decisionImpacts  DecisionGoalImpact[]

  @@index([userId, type])
  @@index([userId, targetDate])
}

model GoalAssetAllocation {
  id              String                  @id @default(cuid())
  goalId          String
  assetId         String
  mode            GoalAssetAllocationMode
  allocationValue Decimal?                @db.Decimal(10, 4)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  goal  Goal  @relation(fields: [goalId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([goalId, assetId])
  @@index([assetId])
}

model Decision {
  id       String           @id @default(cuid())
  userId   String
  template DecisionTemplate
  status   DecisionStatus   @default(DRAFT)
  name     String

  startDate      DateTime?
  durationMonths Int?
  upfrontAmount  Decimal?  @db.Decimal(14, 2)
  monthlyImpact  Decimal?  @db.Decimal(14, 2)

  inputs Json

  assumptionsSnapshot Json?
  baselineSnapshot    Json?
  resultSnapshot      Json?

  verdict         DecisionVerdict?
  confidenceLevel OutputConfidence?
  evaluatedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalImpacts DecisionGoalImpact[]

  @@index([userId, template, updatedAt])
  @@index([userId, status, updatedAt])
}

model DecisionGoalImpact {
  id                   String    @id @default(cuid())
  decisionId           String
  goalId               String
  projectedDelayMonths Int?
  projectedTargetDate  DateTime?
  deltaToTarget        Decimal?  @db.Decimal(14, 2)

  impactSnapshot Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  goal     Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([decisionId, goalId])
  @@index([goalId])
}
